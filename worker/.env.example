# ============================================================
# UrbanGist Worker — Environment Variables
# ============================================================

NODE_ENV=production

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# ── FFmpeg ────────────────────────────────────────────────────
# Path to ffmpeg binary — Railway provides this automatically
# if you use the nixpacks buildpack with ffmpeg in nixpacks.toml
# Leave empty to use system PATH
FFMPEG_PATH=
