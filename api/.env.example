# ============================================================
# UrbanGist API — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# ── Paystack ──────────────────────────────────────────────────
# Found in: Paystack Dashboard → Settings → API Keys & Webhooks
# Use test keys for development, live keys for production
PAYSTACK_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY
PAYSTACK_SECRET_KEY=sk_live_YOUR_SECRET_KEY

# ── CORS ──────────────────────────────────────────────────────
# Your Cloudflare Pages frontend URL
FRONTEND_URL=https://urbangist.com.ng

# ── Security ──────────────────────────────────────────────────
# Random 64-char hex string — generate with: openssl rand -hex 32
IP_HASH_SALT=generate_a_random_64_char_hex_string_here
