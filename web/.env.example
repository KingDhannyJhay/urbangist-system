# ============================================================
# UrbanGist Web — Environment Variables
# Set these in Cloudflare Pages dashboard under Settings → Variables
# ============================================================

# ── API Service (Railway) ─────────────────────────────────────
# Used by next.config.js rewrites to proxy /api/* to Railway
API_URL=https://urbangist-api.up.railway.app

# ── Supabase (client-side only) ───────────────────────────────
# Only anon key goes here — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# ── Paystack (public key only) ────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://urbangist.com.ng
